# =============================================================================
# TUNNEL GMAO - Configuration Environnement
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND PROVIDER - Sélection du backend
# -----------------------------------------------------------------------------
# Détermine quel backend utiliser pour l'application
# Valeurs possibles:
#   - "directus"       : Backend Directus (legacy, toutes fonctionnalités)
#   - "tunnel-backend" : API Python pure (nouveau backend complet)
#   - "hybrid"         : Mode hybride combinant Directus + API Python
#   - "mock"           : Données mockées (développement/tests)
#
# Recommandé: "hybrid" pour migration progressive vers l'API Python
# -----------------------------------------------------------------------------
VITE_BACKEND_PROVIDER=hybrid

# -----------------------------------------------------------------------------
# DIRECTUS API - Backend legacy
# -----------------------------------------------------------------------------
# URL du backend Directus (utilisé en mode "directus" ou "hybrid")
# Gère: auth, préventif, specs stock, manufacturerItems, anomalyConfig
# -----------------------------------------------------------------------------
VITE_DATA_API_URL=http://localhost:8055

# -----------------------------------------------------------------------------
# TUNNEL BACKEND API - Nouveau backend Python
# -----------------------------------------------------------------------------
# URL de l'API Python tunnel-backend (utilisé en mode "tunnel-backend" ou "hybrid")
# Gère: interventions, actions, machines, équipements, stats, achats, stock, exports
# -----------------------------------------------------------------------------
VITE_TUNNEL_BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# DÉVELOPPEMENT - Outils de debug
# -----------------------------------------------------------------------------
# Bloquer les appels API (utile pour développer avec données mockées)
# true = bloque les appels, false = appels normaux
# -----------------------------------------------------------------------------
VITE_BLOCK_API=false

# Endpoints spécifiques à bloquer (séparés par des virgules)
# Exemple: /items/machine,/items/stock,/items/intervention
# -----------------------------------------------------------------------------
VITE_BLOCK_API_ENDPOINTS=/items/machine